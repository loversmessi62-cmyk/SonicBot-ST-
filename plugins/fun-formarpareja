export default {
  commands: ["pareja"],
  category: "fun",

  async run(sock, msg, args, ctx) {
    const jid = ctx.jid

    // verificar grupo
    if (!jid.endsWith("@g.us")) {
      return sock.sendMessage(jid, {
        text: "❌ Este comando solo funciona en grupos"
      }, { quoted: msg })
    }

    // obtener participantes
    let metadata = await sock.groupMetadata(jid)
    let users = metadata.participants.map(p => p.id)

    if (users.length < 2) {
      return sock.sendMessage(jid, {
        text: "❌ Necesito mínimo 2 personas"
      }, { quoted: msg })
    }

    // función random
    const random = arr => arr[Math.floor(Math.random() * arr.length)]

    let user1 = random(users)
    let user2 = random(users)

    // evitar que sea la misma persona
    while (user1 === user2) {
      user2 = random(users)
    }

    // porcentaje
    const love = Math.floor(Math.random() * 101)

    // mensaje
    const text = `💘 *PAREJA DEL GRUPO*

@${user1.split("@")[0]} ❤️ @${user2.split("@")[0]}

💞 Compatibilidad: *${love}%*

> ¿Se gustan o puro show? 😏`

    await sock.sendMessage(jid, {
      text,
      mentions: [user1, user2]
    }, { quoted: msg })
  }
}