// memoria de parejas recientes
let parejasRecientes = []

// función random segura
function getRandom(arr) {
  return arr[Math.floor(Math.random() * arr.length)]
}

// formatear mención
const toM = (a) => '@' + a.split('@')[0]

function handler(m, { groupMetadata }) {
  const ps = groupMetadata.participants.map(v => v.id)

  if (ps.length < 2) {
    return m.reply('❌ Necesito al menos 2 personas para formar pareja')
  }

  let a, b, intento = 0
  let parejaKey

  do {
    a = getRandom(ps)
    b = getRandom(ps)
    parejaKey = [a, b].sort().join('-')
    intento++
  } while (
    (a === b || parejasRecientes.includes(parejaKey)) &&
    intento < 10
  )

  // guardar pareja
  parejasRecientes.push(parejaKey)

  // limitar memoria (últimas 10 parejas)
  if (parejasRecientes.length > 10) {
    parejasRecientes.shift()
  }

  const frases = [
    `💘 *${toM(a)} y ${toM(b)} hacen una pareja perfecta 😍*`,
    `💞 *${toM(a)} debería invitar a ${toM(b)} a salir 😏*`,
    `🔥 *Entre ${toM(a)} y ${toM(b)} hay química 🧪❤️*`,
    `🥰 *${toM(a)} y ${toM(b)} se ven bien juntos 😳*`,
    `💍 *${toM(a)} y ${toM(b)} ya deberían casarse 😍*`,
    `😏 *${toM(a)} no puede negar que le gusta ${toM(b)}*`
  ]

  const resultado = getRandom(frases)

  m.reply(`> ${resultado}\n> *¿Será el inicio de algo bonito? 😏*`, null, {
    mentions: [a, b]
  })
}

handler.help = ['formarpareja']
handler.tags = ['fun']
handler.command = ['formarpareja']
handler.group = true

export default handler