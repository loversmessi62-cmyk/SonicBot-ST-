let parejasRecientes = {}

export default {
  commands: ["formarpareja"],
  category: "fun",

  async run(sock, msg, args, ctx) {
    const jid = ctx.jid

    // obtener metadata correctamente
    const groupMetadata = await sock.groupMetadata(jid)
    const participants = groupMetadata.participants.map(v => v.id)

    if (participants.length < 2) {
      return sock.sendMessage(jid, {
        text: "❌ Necesito al menos 2 personas para formar pareja"
      }, { quoted: msg })
    }

    // init memoria por grupo
    if (!parejasRecientes[jid]) parejasRecientes[jid] = []

    const getRandom = (arr) => arr[Math.floor(Math.random() * arr.length)]
    const toM = (a) => '@' + a.split('@')[0]

    let a, b, key, intento = 0

    do {
      a = getRandom(participants)
      b = getRandom(participants)
      key = [a, b].sort().join('-')
      intento++
    } while (
      (a === b || parejasRecientes[jid].includes(key)) &&
      intento < 10
    )

    // guardar pareja
    parejasRecientes[jid].push(key)

    // limitar historial
    if (parejasRecientes[jid].length > 10) {
      parejasRecientes[jid].shift()
    }

    const frases = [
      `💘 *${toM(a)} y ${toM(b)} hacen una pareja perfecta 😍*`,
      `💞 *${toM(a)} debería invitar a ${toM(b)} a salir 😏*`,
      `🔥 *Entre ${toM(a)} y ${toM(b)} hay química 🧪❤️*`,
      `🥰 *${toM(a)} y ${toM(b)} se ven bien juntos 😳*`,
      `💍 *${toM(a)} y ${toM(b)} ya deberían casarse 😍*`,
      `😏 *${toM(a)} no puede negar que le gusta ${toM(b)}*`
    ]

    const resultado = getRandom(frases)

    await sock.sendMessage(jid, {
      text: `> ${resultado}\n> *¿Será el inicio de algo bonito? 😏*`,
      mentions: [a, b]
    }, { quoted: msg })
  }
}